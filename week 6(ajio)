import java.time.Duration;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class Week6 {

    public static void main(String[] args) {

        System.setProperty("webdriver.chrome.driver", "C:\\Drivers\\chromedriver.exe");

        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();

        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));

        driver.get("https://www.ajio.com");

        WebElement signIn = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.xpath("//span[normalize-space()='Sign In / Join AJIO']")
                )
        );
        signIn.click();

        WebElement joinAjio = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.xpath("//span[normalize-space()='Join AJIO']")
                )
        );
        joinAjio.click();

        driver.findElement(By.name("name")).sendKeys("Mohan");
        driver.findElement(By.name("email")).sendKeys("mohan@gmail.com");
        driver.findElement(By.name("password")).sendKeys("Mohan");

        driver.findElement(By.xpath("//button[contains(text(),'Continue')]")).click();

        driver.quit();
    }
}
